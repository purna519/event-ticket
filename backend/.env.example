# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=your_mongodb_atlas_connection_string_here

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
USER_JWT_SECRET=change_this_to_another_long_random_secret
SUPPORT_ENCRYPTION_KEY=change_this_to_a_64_char_hex_string

# ─── Email Service (Brevo / Gmail SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_app_password

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=https://your-frontend-domain.vercel.app

# ─── Admin Seed Credentials ───────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_immediately

# ─── UPI Payment ──────────────────────────────────────────────────────────────
UPI_ID=your_upi_id@bank
UPI_NAME=Your Name or Brand
UPI_NOTE=TicketPayment

# ─── Event Configuration (Optional Defaults) ──────────────────────────────────
EVENT_NAME=Default Event Name
EVENT_DATE=2026-01-01
EVENT_TIME=06:00 PM
EVENT_VENUE=Default Venue
TICKET_PRICE=499
TOTAL_CAPACITY=150
