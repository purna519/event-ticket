# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/event-ticketing

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── Admin Seed Credentials (used only on first run) ──────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── Event Configuration ──────────────────────────────────────────────────────
EVENT_NAME=Tech Fest 2026
EVENT_DATE=2026-04-15
EVENT_TIME=10:00 AM
EVENT_VENUE=City Convention Centre, Main Hall
EVENT_DESCRIPTION=A spectacular tech festival featuring workshops, speakers, and exhibitions. Join us for an inspiring day of technology and innovation!
TICKET_PRICE=499

# ─── UPI Payment ──────────────────────────────────────────────────────────────
UPI_ID=yourname@upi
UPI_NAME=Tech Fest 2026
UPI_NOTE=TechFest2026Ticket
